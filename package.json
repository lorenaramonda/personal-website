{
  "name": "@lorenaramonda/personal-website",
  "private": true,
  "version": "2.7.1",
  "scripts": {
    "build": "nuxt build --dotenv .env.local",
    "dev-http": "nuxt dev",
    "dev": "nuxt dev --https --ssl-cert localhost.pem --ssl-key localhost-key.pem --dotenv .env.local --host",
    "serve": "nuxt generate && nuxt preview",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest --dom --coverage",
    "lint:js": "eslint --ext \".ts,.vue\" --ignore-path .gitignore .",
    "lint:prettier": "prettier --check .",
    "lint": "pnpm lint:js && pnpm lint:prettier",
    "lintfix": "prettier --write --list-different . && pnpm lint:js --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@sentry/browser": "^9.27.0",
    "@storyblok/vue": "^10.1.8"
  },
  "devDependencies": {
    "@nuxt/image": "^1.9.0",
    "@nuxt/test-utils": "^3.13.1",
    "@nuxtjs/color-mode": "^3.3.2",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/google-fonts": "^3.0.2",
    "@nuxtjs/i18n": "^9.0.0",
    "@pinia/nuxt": "^0.9.0",
    "@storyblok/nuxt": "^10.1.8",
    "@types/node": "^18",
    "@typescript-eslint/parser": "^6.7.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vitest/coverage-istanbul": "^3.2.1",
    "@vue/test-utils": "^2.3.2",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "floating-vue": "^5.0.0",
    "happy-dom": "^20.8.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "nuxt": "^3.21.6",
    "nuxt-gtag": "^0.5.7",
    "nuxt-lazy-load": "^3.0.4",
    "nuxt-lucide-icons": "^1.0.3",
    "pinia": "^2.3.1",
    "prettier": "^3.0.3",
    "sass": "^1.87.0",
    "sass-mq": "file:./local_modules/sass-mq",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1",
    "vue": "^3.5.31"
  },
  "packageManager": "pnpm@10.9.0",
  "lint-staged": {
    "*.{ts,vue,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  }
}
