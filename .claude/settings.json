{
  "permissions": {
    "allow": [
      "Bash(pnpm dev *)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm lint:format)",
      "Bash(pnpm lint:prettier)",
      "Bash(npx vue-tsc *)"
    ],
    "deny": [
      "Read(.env.*)",
      "Write(.env.*)",
      "Write(pnpm-lock.yaml)",
      "Write(node_modules/**)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)"
    ]
  }
}
